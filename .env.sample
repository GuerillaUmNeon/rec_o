TOKEN_API_KEY=your-secret-token-here

POSTGRES=ip
DATABASE=db
DB_USERNAME=username
DB_PASSWORD=password
DB_PORT=5432

# Optional: overrides the vars above
# DATABASE_URL=postgresql://username:password@ip:5432/db

MODEL_BUCKET_NAME=rec-o-models

# Prod artifact on GCS (Cloud Run uses models/knn_baseline_model.pkl via cloudbuild.yaml)
# MODEL_BLOB_NAME=models/knn_baseline_model.pkl

# Local ML saves (run_local) — use a test name to avoid overwriting prod files
MODEL_LOCAL_FILENAME=knn_baseline_model_test.pkl
MODEL_BLOB_NAME=models/knn_baseline_model_test.pkl

# Optional: faster ml training (python -m ml.scripts.run_local --limit N)
ML_MAX_ARTISTS=20000
ML_GENRE_CHUNK_SIZE=2000
