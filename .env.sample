TOKEN_API_KEY=your-secret-token-here

POSTGRES=ip
DATABASE=db
DB_USERNAME=username
DB_PASSWORD=password
DB_PORT=5432

# Optional: overrides the vars above
# DATABASE_URL=postgresql://username:password@ip:5432/db

# --- API: load model at startup (app/predictor.py) ---
# Option A — GCS (Docker / Cloud Run / local without MODEL_LOCAL_PATH):
MODEL_BUCKET_NAME=rec-o-models
MODEL_BLOB_NAME=models/knn_baseline_model_test.pkl

# Option B — local file only (skip GCS). Path relative to project root or absolute:
# MODEL_LOCAL_PATH=models/knn_baseline_model_test.pkl

# --- ML: train + upload (ml/scripts/run_local, upload_to_gcs) ---
MODEL_LOCAL_FILENAME=knn_baseline_model_test.pkl
# MODEL_BLOB_NAME is shared with API for GCS upload destination

# Optional: faster ml training (python -m ml.scripts.run_local --limit N)
ML_MAX_ARTISTS=20000
ML_GENRE_CHUNK_SIZE=2000
